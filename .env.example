DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_mock_interviews
DB_ECHO=0

GROQ_API_KEY=your_groq_api_key_here
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Chat LLM (generation/evaluation/hints): defaults to Groq with the key above.
# To use Gemini instead (e.g. when Groq blocks your hosting region):
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   LLM_API_KEY=<your GEMINI_API_KEY>
#   LLM_MODEL=gemini-2.5-flash
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
# Cheap model for per-utterance calls (intent classification, hints,
# clarifications, probes, follow-ups). Defaults to Groq with GROQ_API_KEY
# even when the main LLM is Gemini, so those calls don't burn Gemini quota.
LLM_FAST_BASE_URL=
LLM_FAST_API_KEY=
LLM_FAST_MODEL=llama-3.1-8b-instant
# Google AI key for embeddings (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768

SECRET_KEY=generate_a_secure_random_string_here
DEBUG=1
EXTERNAL_PORT_FRONTEND=5173
SENTRY_DSN=
SENTRY_DSN_URL=
